# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly LF for source files
*.gleam text eol=lf
*.erl   text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.sh    text eol=lf
*.txt   text eol=lf

# Binary files — no line-ending conversion
*.beam  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
